# Copie para .env e preencha. NÃO comite o .env.
# Em produção (Vercel), defina estas variáveis no painel do projeto.

# Bases da API do Onvio (descobertas por engenharia reversa do app do funcionário).
# Mantidas fora do código pra não serem indexadas pela busca do GitHub.
ONVIO_AUTH_BASE=
ONVIO_DOCS_BASE=

# Segredo que assina o cookie de sessão — use um valor longo e aleatório.
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=
